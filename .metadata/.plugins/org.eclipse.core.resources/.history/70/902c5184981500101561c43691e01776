@import url('https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap');

body{
	margin: 0;
	padding: 0;
	font-family: "Inter", sans-serif;
	font-optical-sizing: auto;
	font-weight: 400;
	font-style: normal;
}

#navbar{
	background: #9C0009;
	height: 20vh;
	max-width:100%;
}

#navbarUL {
  list-style-type: none;
  margin: 0;
  padding: 0;
}

#logo{
	padding: 3vh;
	width: 22vh ;
	height: 15vh ;
}

li {
	padding-top: 7vh;
	padding-right: 6vh;
	display: inline;
}

li {

	float: right;
}

a {
	text-decoration:none; 
	color: #FFFFFF;
	display: block;
	padding: 8px;
}

.apresentação{
	padding-top: 5vh;
	padding-left: 8vh;
	width: 110vh;
}

.apresentação h1{
	color: #740001;
	font-size: 64px;
}

.apresentação p{
	font-size: 24px;
	color: #000000;
}

#imagem{
	position: relative;
	text-align: center;
	color: white;
}

.imgp{
	position: absolute;
  	top: 50%;
  	left: 50%;
  	transform: translate(-50%, 1350%);
  	font-size: 24PX;
  	color: #FFF;
}

.imgh1{
	position: absolute;
  	top: 50%;
  	left: 50%;
  	transform: translate(-50%, 370%);
  	font-size: 64px;
  	color: #FFF;
}



#imagemCapa{
	width: 90%;
	height: 60%;
	padding-top: 8vh;
  	padding-left: 8vh;
}

.botao{
	background-color: #740001; 
	border: none;
    color: white;
    padding: 15px 32px;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    font-size: 24px;
    position: absolute;
  	top: 50%;
  	left: 50%;
  	transform: translate(-50%, 850%);
  	border-radius: 1vh;
}

.produtoH1{
	color: #9C0009;
	font-size: 48px;	
	padding-top: 5vh;
	padding-left: 8vh;
}

.produtosVendidos{
	
	display: flex;
	justify-content: space-around;
	gap: 1em;
}

.bebidasDisplay1, .bebidasDisplay2, .bebidasDisplay3{
	border-style: solid;
	border-width: 1px;
	border-radius: 1vh;
	border-color: #FFBD00;
	
}

.bebidasDisplay1 h6, .bebidasDisplay2 h6, .bebidasDisplay3 h6{
	text-align: center;
	font-size: 24px;
	color: #9C0009;
}
.bebidasDisplay1 p, .bebidasDisplay2 p, .bebidasDisplay3 p{
	font-size: 24px;
	color: #828282;
}

#produtosPresenteaveis h1{
	color: #9C0009;
}

#produtosPresenteaveis{
	padding-top: 5vh;
	padding-left: 8vh;
	display: flex;
}

.presenteaveisTitulo{
	font-size: 24px;
	color:#000000;
}

.presenteaveisTexto{
	font-size: 24px;
	color:#828282;
}

.presenteaveisImagem img{
	width: 95%;
	height: 100%;
	border-radius: 1vh;
}

.botaoPresenteaveis{
	background-color: #FFBD00; 
	border: none;
    color: white;
    padding: 15px 32px;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    font-size: 24px;
  	border-radius: 1vh;
  	margin-top: 25vh;
}

#nossasMarcas{
	
}

.botaoMarcas{
	font-size: 24px;
}